# ============================================================
# Alternative SMTP Providers (uncomment one below)
# ============================================================

# For Gmail (most common):
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587

# For Microsoft Outlook:
# SMTP_SERVER=smtp-mail.outlook.com
# SMTP_PORT=587

# For Yahoo Mail:
# SMTP_SERVER=smtp.mail.yahoo.com
# SMTP_PORT=587

# For Custom SMTP Server:
# SMTP_SERVER=your-smtp-server.com
# SMTP_PORT=587  # or 25, 465 depending on your server

# ============================================================
# Testing with MailHog (local development)
# ============================================================
# For local testing without real emails:
# Install MailHog: https://github.com/mailhog/MailHog
# Run: mailhog
# Then configure:
# SMTP_SERVER=localhost
# SMTP_PORT=1025
# SENDER_EMAIL=test@example.com
# SENDER_PASSWORD=  (leave empty)
# Visit http://localhost:1025 to see captured emails
